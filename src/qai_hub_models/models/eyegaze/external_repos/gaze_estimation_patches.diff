# Fix float64 index tensors in softargmax2d that prevent NPU execution.
# np.linspace produces float64 by default; passing dtype=np.float32 keeps
# the index constants as float32 so the entire graph stays on float32 and
# QNN can dispatch all ops to the NPU.
diff --git a/util/softargmax.py b/util/softargmax.py
index 222f8f7..f596ba5 100644
--- a/util/softargmax.py
+++ b/util/softargmax.py
@@ -10,8 +10,8 @@ def softargmax2d(input, beta=100, dtype=torch.float32):
     input = nn.functional.softmax(beta * input, dim=-1)
 
     indices_c, indices_r = np.meshgrid(
-        np.linspace(0, 1, w),
-        np.linspace(0, 1, h),
+        np.linspace(0, 1, w, dtype=np.float32),
+        np.linspace(0, 1, h, dtype=np.float32),
         indexing='xy'
     )
 
